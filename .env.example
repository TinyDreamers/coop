# ---------------------------------------------------------------------------
# Coop Planner environment variables
# Copy this file to `.env.local` for local dev, and set the same values in the
# Vercel dashboard (Project Settings > Environment Variables) for production.
# ---------------------------------------------------------------------------

# Simple password gate. The app has no user accounts — just this shared password.
# Defaults to "coop" if unset.
APP_PASSWORD=coop

# Vercel Blob read/write token — used as the "database" for the single coop
# project JSON document and for uploaded reference photos.
# Get it by creating a Blob store in the Vercel dashboard (Storage > Create > Blob),
# then run `vercel env pull` or copy the token here.
# If this is MISSING, the app still works: it falls back to browser localStorage
# for persistence and disables server-side photo uploads (photos use local
# object URLs instead). Nothing breaks — you just lose cross-device sync.
BLOB_READ_WRITE_TOKEN=

# Optional: a secret used to sign the auth cookie. Defaults to a static dev value.
# Set to any random string in production.
AUTH_SECRET=dev-secret-change-me
